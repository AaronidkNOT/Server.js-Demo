# Copiá este archivo como ".env" (sin ".example") y ajustá los valores.
# El archivo ".env" real NUNCA se sube al repositorio (ver .gitignore).

# Puerto en el que va a correr el servidor
PORT=3000

# Clave secreta usada para firmar los tokens JWT.
# Para esta demo podés dejar cualquier valor, pero si llegás a desplegar
# esto en serio, usá una clave larga y aleatoria. Por ejemplo, podés generar
# una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambiame-por-una-clave-larga-y-aleatoria

# Origen permitido para CORS. Con "*" cualquier sitio puede llamar a la API
# (cómodo para la demo). Si separás el frontend del backend en producción,
# poné aquí el dominio exacto del frontend, por ejemplo:
# ALLOWED_ORIGIN=https://mi-frontend.com
ALLOWED_ORIGIN=*
